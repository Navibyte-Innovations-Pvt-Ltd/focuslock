#!/bin/bash
# focuslock — temporary site blocker for macOS
# Config: ~/.focuslock/sites

CONFIG_DIR="$HOME/.focuslock"
SITES_FILE="$CONFIG_DIR/sites"
PIDFILE="/tmp/focuslock.pid"
ALLOWED_FILE="/tmp/focuslock-allowed"
HOSTS="/etc/hosts"
LOG="/tmp/focuslock.log"

# Elevate for commands that touch /etc/hosts
COMMAND="${1:-help}"
case "$COMMAND" in
  allow|block|add|remove)
    [ "$EUID" -ne 0 ] && exec sudo "$0" "$@"
    ;;
esac

ensure_config() {
  mkdir -p "$CONFIG_DIR"
  if [ ! -f "$SITES_FILE" ]; then
    cat > "$SITES_FILE" << 'DEFAULTS'
linkedin.com
facebook.com
instagram.com
amazon.in
youtube.com
DEFAULTS
  fi
}

read_sites() {
  ensure_config
  while IFS= read -r line; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    echo "$line"
  done < "$SITES_FILE"
}

close_chrome_tabs() {
  local domains_as=""
  while IFS= read -r site; do
    domains_as="${domains_as}\"${site}\", "
  done < "$SITES_FILE"
  domains_as="${domains_as%, }"

  local LOGGED_USER
  LOGGED_USER=$(stat -f "%Su" /dev/console)
  # Only run if Chrome is already open — osascript launches Chrome if not running, causing hang
  if pgrep -x "Google Chrome" > /dev/null 2>&1; then
    sudo -u "$LOGGED_USER" osascript << APPLESCRIPT 2>/dev/null
tell application "Google Chrome"
    set blockedDomains to {${domains_as}}
    repeat with w in windows
        set tabsToClose to {}
        repeat with t in tabs of w
            set tabURL to URL of t
            repeat with domain in blockedDomains
                if tabURL contains (domain as string) then
                    set end of tabsToClose to t
                    exit repeat
                end if
            end repeat
        end repeat
        repeat with t in reverse of tabsToClose
            close t
        end repeat
    end repeat
end tell
APPLESCRIPT
  fi
}

# Pick N unique random letters from a confusion-free pool.
# Forces user to read labels every run instead of muscle-memory typing.
random_labels() {
  local n=$1
  printf '%s\n' b c d e f g h j k m n p q r s t u v w x y z \
    | awk 'BEGIN{srand()}{print rand()"\t"$0}' \
    | sort -k1,1n | cut -f2 | head -n "$n"
}

# Shuffle a list of lines.
shuffle_lines() {
  awk 'BEGIN{srand()}{print rand()"\t"$0}' | sort -k1,1n | cut -f2-
}

cmd_allow() {
  ensure_config

  # Build site list, then shuffle order so position changes every run
  sites=()
  while IFS= read -r site; do
    sites+=("$site")
  done < <(read_sites | shuffle_lines)

  [ ${#sites[@]} -eq 0 ] && echo "No sites in config. Run: focuslock add <domain>" && exit 1

  # Random letter labels — one per site, plus one for "all"
  site_labels=()
  while IFS= read -r lbl; do
    site_labels+=("$lbl")
  done < <(random_labels $((${#sites[@]} + 1)))

  all_label="${site_labels[${#sites[@]}]}"

  echo ""
  echo "Which sites to allow?"
  for ((i=0; i<${#sites[@]}; i++)); do
    echo "  ${site_labels[$i]}) ${sites[$i]}"
  done
  echo "  ${all_label}) All"
  echo ""
  read -rp "Choice [e.g. ${site_labels[0]} ${site_labels[1]} or '${all_label}']: " site_input

  selected=()
  # Tokenize input on whitespace/commas
  tokens=$(echo "$site_input" | tr ',' ' ')
  use_all=0
  for tok in $tokens; do
    [ "$tok" = "$all_label" ] && use_all=1 && break
  done

  if [ $use_all -eq 1 ]; then
    selected=("${sites[@]}")
  else
    for tok in $tokens; do
      matched=0
      for ((i=0; i<${#sites[@]}; i++)); do
        if [ "$tok" = "${site_labels[$i]}" ]; then
          selected+=("${sites[$i]}")
          matched=1
          break
        fi
      done
      [ $matched -eq 0 ] && echo "  Skipping unknown: $tok"
    done
  fi

  [ ${#selected[@]} -eq 0 ] && echo "No valid sites selected. Exiting." && exit 1

  # Duration: shuffle order + random labels too
  dur_mins=(5 10 30 60 120)
  dur_text=("5 min" "10 min" "30 min" "1 hour" "2 hours")

  dur_order=()
  while IFS= read -r idx; do
    dur_order+=("$idx")
  done < <(seq 0 $((${#dur_mins[@]} - 1)) | shuffle_lines)

  dur_labels=()
  while IFS= read -r lbl; do
    dur_labels+=("$lbl")
  done < <(random_labels ${#dur_mins[@]})

  echo ""
  echo "Allow for how long?"
  for ((i=0; i<${#dur_order[@]}; i++)); do
    real_idx="${dur_order[$i]}"
    echo "  ${dur_labels[$i]}) ${dur_text[$real_idx]}"
  done
  echo ""
  read -rp "Choice: " t

  MINUTES=""
  for ((i=0; i<${#dur_labels[@]}; i++)); do
    if [ "$t" = "${dur_labels[$i]}" ]; then
      real_idx="${dur_order[$i]}"
      MINUTES="${dur_mins[$real_idx]}"
      break
    fi
  done
  [ -z "$MINUTES" ] && echo "Invalid choice. Exiting." && exit 1

  # Confirmation prompt — must type a random short code
  CONFIRM_CODE=$(printf '%s' "${site_labels[@]:0:3}" | tr -d '\n')
  [ -z "$CONFIRM_CODE" ] && CONFIRM_CODE="${site_labels[0]}"
  echo ""
  echo "About to allow: ${selected[*]}"
  echo "Duration      : $MINUTES min"
  read -rp "Type '$CONFIRM_CODE' to confirm: " confirm_input
  if [ "$confirm_input" != "$CONFIRM_CODE" ]; then
    echo "Confirmation failed. Exiting."
    exit 1
  fi

  # Kill existing timer
  [ -f "$PIDFILE" ] && kill "$(cat $PIDFILE)" 2>/dev/null && rm -f "$PIDFILE"

  # Save selected for reblock
  printf '%s\n' "${selected[@]}" > "$ALLOWED_FILE"

  # Comment out selected sites in /etc/hosts
  for site in "${selected[@]}"; do
    base="${site#www.}"
    escaped="${base//./\\.}"
    sed -i '' -E "/^127\.0\.0\.1[[:space:]]+(www\.)?${escaped}/s/^/# /" "$HOSTS"
  done

  dscacheutil -flushcache
  killall -HUP mDNSResponder 2>/dev/null

  REBLOCK_AT=$(date -v+${MINUTES}M '+%I:%M %p')
  echo ""
  echo "Allowed : ${selected[*]}"
  echo "Reblocks: $REBLOCK_AT"

  SCRIPT_PATH="$0"
  nohup bash -c "sleep $((MINUTES * 60)) && '$SCRIPT_PATH' block" > "$LOG" 2>&1 &
  echo $! > "$PIDFILE"
  echo "Timer PID: $(cat $PIDFILE)"
}

cmd_block() {
  ensure_config

  if [ -f "$ALLOWED_FILE" ]; then
    while IFS= read -r site; do
      base="${site#www.}"
      escaped="${base//./\\.}"
      sed -i '' -E "s/^#[[:space:]]*(127\.0\.0\.1[[:space:]]+(www\.)?${escaped})/\1/" "$HOSTS"
    done < "$ALLOWED_FILE"
    rm -f "$ALLOWED_FILE"
  else
    while IFS= read -r site; do
      base="${site#www.}"
      escaped="${base//./\\.}"
      sed -i '' -E "s/^#[[:space:]]*(127\.0\.0\.1[[:space:]]+(www\.)?${escaped})/\1/" "$HOSTS"
    done < <(read_sites)
  fi

  dscacheutil -flushcache
  killall -HUP mDNSResponder 2>/dev/null
  close_chrome_tabs

  echo "$(date '+%I:%M %p'): Sites re-blocked" | tee -a "$LOG"
  rm -f "$PIDFILE"
}

cmd_add() {
  ensure_config
  local site="${1#www.}"
  [ -z "$site" ] && echo "Usage: focuslock add <domain>" && exit 1

  if grep -qxF "$site" "$SITES_FILE" 2>/dev/null; then
    echo "$site already in list"
    exit 0
  fi

  echo "$site" >> "$SITES_FILE"

  if ! grep -qE "127\.0\.0\.1[[:space:]]+${site//./\\.}" "$HOSTS"; then
    printf "127.0.0.1\t%s\n127.0.0.1\twww.%s\n" "$site" "$site" >> "$HOSTS"
  fi

  dscacheutil -flushcache
  killall -HUP mDNSResponder 2>/dev/null
  echo "Added and blocked: $site"
}

cmd_remove() {
  ensure_config
  local site="${1#www.}"
  [ -z "$site" ] && echo "Usage: focuslock remove <domain>" && exit 1

  sed -i '' "/^${site}$/d" "$SITES_FILE"
  sed -i '' -E "/127\.0\.0\.1[[:space:]]+(www\.)?${site//./\\.}/d" "$HOSTS"

  dscacheutil -flushcache
  killall -HUP mDNSResponder 2>/dev/null
  echo "Removed: $site"
}

cmd_list() {
  ensure_config
  echo "Blocked sites:"
  while IFS= read -r site; do
    escaped="${site//./\\.}"
    if grep -qE "^#[[:space:]]*127\.0\.0\.1[[:space:]]+(www\.)?${escaped}" "$HOSTS" 2>/dev/null; then
      echo "  $site  [ALLOWED now]"
    else
      echo "  $site  [blocked]"
    fi
  done < <(read_sites)
}

cmd_status() {
  if [ -f "$PIDFILE" ]; then
    PID=$(cat "$PIDFILE")
    if kill -0 "$PID" 2>/dev/null; then
      echo "Status: ALLOWING"
      [ -f "$ALLOWED_FILE" ] && echo "Sites:" && sed 's/^/  /' "$ALLOWED_FILE"
    else
      echo "Status: BLOCKED (timer expired or killed)"
      rm -f "$PIDFILE"
    fi
  else
    echo "Status: BLOCKED"
  fi
}

cmd_help() {
  cat << 'HELP'
focuslock — temporary site blocker for macOS

Usage:
  sudo focuslock allow          pick sites + duration, auto-reblocks
  sudo focuslock block          reblock immediately
  sudo focuslock add <domain>   add site to block list
  sudo focuslock remove <domain> remove site from block list
  focuslock list                show all sites + current state
  focuslock status              show timer status

Config: ~/.focuslock/sites (one domain per line)
HELP
}

case "$COMMAND" in
  allow)  shift; cmd_allow "$@" ;;
  block)  shift; cmd_block "$@" ;;
  add)    shift; cmd_add "$@" ;;
  remove) shift; cmd_remove "$@" ;;
  list)   cmd_list ;;
  status) cmd_status ;;
  *)      cmd_help ;;
esac
