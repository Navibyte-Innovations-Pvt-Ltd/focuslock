#!/bin/bash
# focuslock — temporary site blocker for macOS
# Config: ~/.focuslock/sites

# Detect a real home dir. When invoked by LaunchDaemon, $HOME is unset/empty,
# which made CONFIG_DIR resolve to /.focuslock on the read-only root volume.
detect_home() {
  if [ -n "$HOME" ] && [ "$HOME" != "/" ] && [ -d "$HOME" ]; then
    echo "$HOME"
    return
  fi
  local console_user
  console_user=$(stat -f "%Su" /dev/console 2>/dev/null)
  if [ -n "$console_user" ] && [ "$console_user" != "root" ] && [ -d "/Users/$console_user" ]; then
    echo "/Users/$console_user"
    return
  fi
  echo "/var/root"
}

CONFIG_DIR="$(detect_home)/.focuslock"
SITES_FILE="$CONFIG_DIR/sites"

# Persistent state — survives reboot (unlike /tmp on macOS)
STATE_DIR="/var/db/focuslock"
PIDFILE="$STATE_DIR/timer.pid"
ALLOWED_FILE="$STATE_DIR/allowed"
EXPIRES_FILE="$STATE_DIR/expires-at"
HISTORY_FILE="$STATE_DIR/history.log"
HOSTS="/etc/hosts"
LOG="$STATE_DIR/focuslock.log"

DAEMON_PLIST="/Library/LaunchDaemons/dev.focuslock.reblock.plist"
DAEMON_LABEL="dev.focuslock.reblock"

DNSMASQ_PLIST="/Library/LaunchDaemons/homebrew.mxcl.dnsmasq.plist"
DNS_LOG="$STATE_DIR/dns.log"
DNS_IFACE_BACKUP="$STATE_DIR/dns-interfaces"

ensure_state_dir() {
  [ -d "$STATE_DIR" ] || mkdir -p "$STATE_DIR"
}

# Flush OS DNS *and* dnsmasq. The DNS tracker (dnsmasq) becomes the system
# resolver (DNS=127.0.0.1) and caches /etc/hosts, only re-reading it on SIGHUP.
# Without the SIGHUP, allow/block edits to /etc/hosts never reach the resolver,
# so a site stays blocked/allowed regardless of the hosts file.
flush_dns() {
  dscacheutil -flushcache
  killall -HUP mDNSResponder 2>/dev/null
  killall -HUP dnsmasq 2>/dev/null
}

# Collapse duplicate focuslock-managed /etc/hosts entries to one line per
# (ip, host). Duplicates with conflicting state (one commented, one active)
# caused sites to stay blocked even while "allowed": the stray active line wins.
# State of the surviving line is derived from the current allow window:
# commented (allowed) if the base domain is in ALLOWED_FILE and not expired,
# otherwise active (blocked). Idempotent.
dedup_hosts() {
  [ -w "$HOSTS" ] || return 0
  local now exp allowed_list
  now=$(date +%s)
  exp=0
  [ -f "$EXPIRES_FILE" ] && exp=$(cat "$EXPIRES_FILE" 2>/dev/null || echo 0)
  [ -z "$exp" ] && exp=0
  allowed_list=""
  if [ -f "$ALLOWED_FILE" ] && [ "$exp" -gt "$now" ]; then
    allowed_list=$(tr '\n' ' ' < "$ALLOWED_FILE")
  fi

  local tmp
  tmp=$(mktemp) || return 0
  awk -v allowed="$allowed_list" '
    BEGIN { n=split(allowed, a, " "); for (i=1;i<=n;i++) if (a[i]!="") allow[a[i]]=1 }
    {
      bare=$0; sub(/^#[[:space:]]*/, "", bare)
      if (bare ~ /^(127\.0\.0\.1|::1)[[:space:]]+[^[:space:]]/) {
        split(bare, f, /[[:space:]]+/)
        ip=f[1]; host=f[2]
        if (host=="localhost") { print; next }
        key=ip" "host
        if (key in seen) next
        seen[key]=1
        base=host; sub(/^www\./, "", base)
        if (base in allow) print "# " ip "\t" host
        else            print ip "\t" host
        next
      }
      print
    }
  ' "$HOSTS" > "$tmp"

  # Safety: only commit if output is non-empty and still has localhost
  if [ -s "$tmp" ] && grep -q "localhost" "$tmp"; then
    cat "$tmp" > "$HOSTS"
  fi
  rm -f "$tmp"
}

history_log() {
  ensure_state_dir
  printf '%s | %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" >> "$HISTORY_FILE"
}

# Elevate for commands that touch /etc/hosts or state dir
COMMAND="${1:-help}"
case "$COMMAND" in
  allow|block|add|remove|check|install-daemon|uninstall-daemon|disable-chrome-doh|update|install-tracker|uninstall-tracker)
    [ "$EUID" -ne 0 ] && exec sudo "$0" "$@"
    ;;
esac

ensure_config() {
  mkdir -p "$CONFIG_DIR"
  if [ ! -f "$SITES_FILE" ]; then
    cat > "$SITES_FILE" << 'DEFAULTS'
linkedin.com
facebook.com
instagram.com
amazon.in
youtube.com
DEFAULTS
  fi
}

read_sites() {
  ensure_config
  while IFS= read -r line; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    echo "$line"
  done < "$SITES_FILE"
}

# Strip lines previous buggy `add` left behind, where the "domain" still
# contained protocol/path/port. Idempotent. Runs before any sed pattern below
# would interact with the malformed entries.
repair_bad_entries() {
  [ -w "$HOSTS" ] || return 0
  # Delete /etc/hosts lines for 127.0.0.1 or ::1 whose host field has
  # URL chars (://, /, :, ?) — those never match real DNS.
  sed -i '' -E '/^#?[[:space:]]*(127\.0\.0\.1|::1)[[:space:]]+[^[:space:]]*(:\/\/|\/|\?|:[0-9])/d' "$HOSTS"
  # Same cleanup in the sites file — keep blanks and `# comment` lines.
  if [ -f "$SITES_FILE" ] && [ -w "$SITES_FILE" ]; then
    sed -i '' -E '/^[^#[:space:]].*[:\/?]/d' "$SITES_FILE"
  fi
  dedup_hosts
}

# Many sites (YouTube/Google) resolve via IPv6 — without ::1 entries they
# bypass IPv4 /etc/hosts entirely. Mirror IPv4 state into ::1 lines.
# Idempotent; safe to call on every privileged command.
migrate_ipv6_hosts() {
  [ -w "$HOSTS" ] || return 0
  while IFS= read -r site; do
    local esc="${site//./\\.}"
    # Already has ::1 entry — skip
    if grep -qE "^#?[[:space:]]*::1[[:space:]]+(www\.)?${esc}([[:space:]]|$)" "$HOSTS"; then
      continue
    fi
    if grep -qE "^#[[:space:]]*127\.0\.0\.1[[:space:]]+(www\.)?${esc}([[:space:]]|$)" "$HOSTS"; then
      # IPv4 commented (allowed) → mirror commented
      printf "# ::1\t%s\n# ::1\twww.%s\n" "$site" "$site" >> "$HOSTS"
    elif grep -qE "^127\.0\.0\.1[[:space:]]+(www\.)?${esc}([[:space:]]|$)" "$HOSTS"; then
      # IPv4 active (blocked) → mirror active
      printf "::1\t%s\n::1\twww.%s\n" "$site" "$site" >> "$HOSTS"
    fi
  done < <(read_sites)
}

close_chrome_tabs() {
  # Use read_sites (skips blank/comment lines) — a blank line here becomes an
  # empty domain, and AppleScript `tabURL contains ""` matches EVERY tab,
  # closing all of Chrome instead of just blocked-site tabs.
  local domains_as=""
  while IFS= read -r site; do
    [ -z "$site" ] && continue
    domains_as="${domains_as}\"${site}\", "
  done < <(read_sites)
  domains_as="${domains_as%, }"
  [ -z "$domains_as" ] && return 0

  local LOGGED_USER
  LOGGED_USER=$(stat -f "%Su" /dev/console)
  # Only run if Chrome is already open — osascript launches Chrome if not running, causing hang
  if pgrep -x "Google Chrome" > /dev/null 2>&1; then
    sudo -u "$LOGGED_USER" osascript << APPLESCRIPT 2>/dev/null
tell application "Google Chrome"
    set blockedDomains to {${domains_as}}
    repeat with w in windows
        set tabsToClose to {}
        repeat with t in tabs of w
            set tabURL to URL of t
            repeat with domain in blockedDomains
                if tabURL contains (domain as string) then
                    set end of tabsToClose to t
                    exit repeat
                end if
            end repeat
        end repeat
        repeat with t in reverse of tabsToClose
            close t
        end repeat
    end repeat
end tell
APPLESCRIPT
  fi
}

# Pick N unique random letters from a confusion-free pool.
# Forces user to read labels every run instead of muscle-memory typing.
random_labels() {
  local n=$1
  printf '%s\n' b c d e f g h j k m n p q r s t u v w x y z \
    | awk 'BEGIN{srand()}{print rand()"\t"$0}' \
    | sort -k1,1n | cut -f2 | head -n "$n"
}

# Shuffle a list of lines.
shuffle_lines() {
  awk 'BEGIN{srand()}{print rand()"\t"$0}' | sort -k1,1n | cut -f2-
}

# Read history.log + print today total + per-site last-allow stamps.
# Pure read, no state changes. Quiet if no history.
show_usage_stats() {
  [ ! -f "$HISTORY_FILE" ] && return
  local today total_today
  today=$(date '+%Y-%m-%d')

  total_today=$(awk -F' \\| ' -v today="$today" '
    {
      split($1, dp, " ")
      if (dp[1] != today) next
      if ($2 !~ /^ALLOW /) next
      split($2, parts, " ")
      mins = parts[2]; sub(/m$/, "", mins)
      sum += mins + 0
    }
    END { print sum+0 }
  ' "$HISTORY_FILE")

  echo ""
  echo "Today: ${total_today} min allowed total"
  echo ""
  echo "Last allowed:"
  local any=0
  while IFS= read -r site; do
    local last ts mins pretty
    last=$(awk -F' \\| ' -v site="$site" '
      $2 ~ /^ALLOW / {
        idx = index($2, ": ")
        if (idx == 0) next
        list = substr($2, idx+2)
        n = split(list, sites, " ")
        for (i=1; i<=n; i++) if (sites[i] == site) { print $0; break }
      }
    ' "$HISTORY_FILE" | tail -n1)
    if [ -n "$last" ]; then
      ts=$(awk -F' \\| ' '{print $1}' <<< "$last")
      mins=$(awk -F' \\| ' '{print $2}' <<< "$last" | awk '{print $2}' | tr -d 'm:')
      pretty=$(date -j -f '%Y-%m-%d %H:%M:%S' "$ts" '+%-I:%M %p, %b %d' 2>/dev/null)
      printf "  %-18s %s for %s min\n" "$site" "${pretty:-$ts}" "$mins"
      any=1
    fi
  done < <(read_sites)
  [ "$any" = "0" ] && echo "  (no previous allows yet)"
  return 0
}

cmd_allow() {
  ensure_config
  show_usage_stats

  # Build site list, then shuffle order so position changes every run
  sites=()
  while IFS= read -r site; do
    sites+=("$site")
  done < <(read_sites | shuffle_lines)

  [ ${#sites[@]} -eq 0 ] && echo "No sites in config. Run: focuslock add <domain>" && exit 1

  # Random letter labels — one per site, plus one for "all"
  site_labels=()
  while IFS= read -r lbl; do
    site_labels+=("$lbl")
  done < <(random_labels $((${#sites[@]} + 1)))

  all_label="${site_labels[${#sites[@]}]}"

  echo ""
  echo "Which sites to allow?"
  for ((i=0; i<${#sites[@]}; i++)); do
    echo "  ${site_labels[$i]}) ${sites[$i]}"
  done
  echo "  ${all_label}) All"
  echo ""
  read -rp "Choice [e.g. ${site_labels[0]} ${site_labels[1]} or '${all_label}']: " site_input

  selected=()
  # Tokenize input on whitespace/commas
  tokens=$(echo "$site_input" | tr ',' ' ')
  use_all=0
  for tok in $tokens; do
    [ "$tok" = "$all_label" ] && use_all=1 && break
  done

  if [ $use_all -eq 1 ]; then
    selected=("${sites[@]}")
  else
    for tok in $tokens; do
      matched=0
      for ((i=0; i<${#sites[@]}; i++)); do
        if [ "$tok" = "${site_labels[$i]}" ]; then
          selected+=("${sites[$i]}")
          matched=1
          break
        fi
      done
      [ $matched -eq 0 ] && echo "  Skipping unknown: $tok"
    done
  fi

  [ ${#selected[@]} -eq 0 ] && echo "No valid sites selected. Exiting." && exit 1

  # Duration: shuffle order + random labels too
  dur_mins=(5 10 30 60 120)
  dur_text=("5 min" "10 min" "30 min" "1 hour" "2 hours")

  dur_order=()
  while IFS= read -r idx; do
    dur_order+=("$idx")
  done < <(seq 0 $((${#dur_mins[@]} - 1)) | shuffle_lines)

  dur_labels=()
  while IFS= read -r lbl; do
    dur_labels+=("$lbl")
  done < <(random_labels ${#dur_mins[@]})

  echo ""
  echo "Allow for how long?"
  for ((i=0; i<${#dur_order[@]}; i++)); do
    real_idx="${dur_order[$i]}"
    echo "  ${dur_labels[$i]}) ${dur_text[$real_idx]}"
  done
  echo ""
  read -rp "Choice: " t

  MINUTES=""
  for ((i=0; i<${#dur_labels[@]}; i++)); do
    if [ "$t" = "${dur_labels[$i]}" ]; then
      real_idx="${dur_order[$i]}"
      MINUTES="${dur_mins[$real_idx]}"
      break
    fi
  done
  [ -z "$MINUTES" ] && echo "Invalid choice. Exiting." && exit 1

  # Confirmation prompt — must type a random short code
  CONFIRM_CODE=$(printf '%s' "${site_labels[@]:0:3}" | tr -d '\n')
  [ -z "$CONFIRM_CODE" ] && CONFIRM_CODE="${site_labels[0]}"
  echo ""
  echo "About to allow: ${selected[*]}"
  echo "Duration      : $MINUTES min"
  read -rp "Type '$CONFIRM_CODE' to confirm: " confirm_input
  if [ "$confirm_input" != "$CONFIRM_CODE" ]; then
    echo "Confirmation failed. Exiting."
    exit 1
  fi

  ensure_state_dir

  # Kill existing timer
  [ -f "$PIDFILE" ] && kill "$(cat $PIDFILE)" 2>/dev/null && rm -f "$PIDFILE"

  # Merge with currently-allowed sites that haven't expired yet —
  # a second `allow` must not orphan the first set by overwriting ALLOWED_FILE.
  MERGED=("${selected[@]}")
  PREV_EXP=0
  [ -f "$EXPIRES_FILE" ] && PREV_EXP=$(cat "$EXPIRES_FILE" 2>/dev/null || echo 0)
  if [ -f "$ALLOWED_FILE" ] && [ "$PREV_EXP" -gt "$(date +%s)" ]; then
    while IFS= read -r _existing; do
      _already=0
      for _s in "${MERGED[@]}"; do [ "$_s" = "$_existing" ] && _already=1 && break; done
      [ $_already -eq 0 ] && MERGED+=("$_existing")
    done < "$ALLOWED_FILE"
  fi

  # Save merged list for reblock + expiry epoch (used by check + daemon)
  printf '%s\n' "${MERGED[@]}" > "$ALLOWED_FILE"
  NEW_EXP=$(($(date +%s) + MINUTES * 60))
  # Keep max expiry — don't cut short a site from a prior allow
  [ "$PREV_EXP" -gt "$NEW_EXP" ] && EXPIRES_AT=$PREV_EXP || EXPIRES_AT=$NEW_EXP
  echo "$EXPIRES_AT" > "$EXPIRES_FILE"

  history_log "ALLOW ${MINUTES}m: ${selected[*]}"

  # Make sure reblock daemon is installed (survives reboot)
  if [ ! -f "$DAEMON_PLIST" ]; then
    install_daemon_silent
  fi

  repair_bad_entries
  migrate_ipv6_hosts

  # Comment out selected sites in /etc/hosts (both IPv4 and IPv6 lines)
  for site in "${selected[@]}"; do
    base="${site#www.}"
    escaped="${base//./\\.}"
    sed -i '' -E "/^(127\.0\.0\.1|::1)[[:space:]]+(www\.)?${escaped}/s/^/# /" "$HOSTS"
  done

  flush_dns

  # Chrome caches 127.0.0.1 internally for ~60s after OS DNS flush.
  # Open chrome://net-internals/#dns so user can clear it without losing tabs.
  local LOGGED_USER
  LOGGED_USER=$(stat -f "%Su" /dev/console)
  if pgrep -x "Google Chrome" > /dev/null 2>&1; then
    sudo -u "$LOGGED_USER" osascript -e 'tell application "Google Chrome" to make new tab at end of tabs of front window with properties {URL:"chrome://net-internals/#dns"}' 2>/dev/null
    echo "  Chrome: click 'Clear host cache' in the new tab, then close it"
  fi

  REBLOCK_AT=$(date -v+"${MINUTES}"M '+%I:%M %p')
  echo ""
  echo "Allowed : ${selected[*]}"
  echo "Reblocks: $REBLOCK_AT  (LaunchDaemon checks every 60s — survives reboot)"
}

cmd_block() {
  ensure_config
  ensure_state_dir
  repair_bad_entries
  migrate_ipv6_hosts

  blocked_sites=""
  if [ -f "$ALLOWED_FILE" ]; then
    while IFS= read -r site; do
      base="${site#www.}"
      escaped="${base//./\\.}"
      sed -i '' -E "s/^#[[:space:]]*((127\.0\.0\.1|::1)[[:space:]]+(www\.)?${escaped})/\1/" "$HOSTS"
      blocked_sites="$blocked_sites $site"
    done < "$ALLOWED_FILE"
    rm -f "$ALLOWED_FILE"
  else
    while IFS= read -r site; do
      base="${site#www.}"
      escaped="${base//./\\.}"
      sed -i '' -E "s/^#[[:space:]]*((127\.0\.0\.1|::1)[[:space:]]+(www\.)?${escaped})/\1/" "$HOSTS"
      blocked_sites="$blocked_sites $site"
    done < <(read_sites)
  fi

  flush_dns
  close_chrome_tabs

  echo "$(date '+%I:%M %p'): Sites re-blocked" | tee -a "$LOG"
  history_log "BLOCK:${blocked_sites}"
  rm -f "$PIDFILE" "$EXPIRES_FILE"
}

# Called by LaunchDaemon every 60s. Re-blocks if expiry passed.
# Also handles the "laptop slept/rebooted past expiry" case.
cmd_check() {
  [ -f "$EXPIRES_FILE" ] || exit 0
  EXP=$(cat "$EXPIRES_FILE" 2>/dev/null)
  [ -z "$EXP" ] && exit 0
  NOW=$(date +%s)
  if [ "$NOW" -ge "$EXP" ]; then
    history_log "CHECK: expired (now=$NOW exp=$EXP) -> block"
    cmd_block
  fi
}

install_daemon_silent() {
  ensure_state_dir
  local script_path
  script_path=$(command -v focuslock 2>/dev/null || echo "/usr/local/bin/focuslock")
  cat > "$DAEMON_PLIST" << PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>${DAEMON_LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>${script_path}</string>
    <string>check</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>StartInterval</key><integer>60</integer>
  <key>StandardOutPath</key><string>${LOG}</string>
  <key>StandardErrorPath</key><string>${LOG}</string>
</dict>
</plist>
PLIST
  chown root:wheel "$DAEMON_PLIST"
  chmod 644 "$DAEMON_PLIST"
  launchctl unload "$DAEMON_PLIST" 2>/dev/null
  launchctl load -w "$DAEMON_PLIST" 2>/dev/null
}

cmd_install_daemon() {
  install_daemon_silent
  echo "Daemon installed: $DAEMON_PLIST"
  echo "Runs every 60s, including at boot — auto-reblocks if expiry passed."
}

# Chrome bypasses /etc/hosts via three mechanisms:
#   1. DNS-over-HTTPS — sends DNS directly to Cloudflare/Google over HTTPS
#   2. Built-in DNS client — Chrome's own resolver, ignores OS /etc/hosts
#   3. QUIC/HTTP3 — connects to cached IPs, skips DNS entirely
# /Library/Managed Preferences/ requires MDM enrollment — Chrome ignores it on standalone Macs.
# JSON policy files in /Library/Application Support/Google/Chrome/policies/managed/
# are read by Chrome unconditionally as mandatory policies, no MDM required.
cmd_disable_chrome_doh() {
  local policy_dir="/Library/Application Support/Google/Chrome/policies/managed"
  local policy_file="${policy_dir}/focuslock.json"
  mkdir -p "$policy_dir"
  cat > "$policy_file" << 'POLICY'
{
  "BuiltInDnsClientEnabled": false,
  "DnsOverHttpsMode": "off",
  "QuicAllowed": false
}
POLICY
  chown -R root:wheel "$policy_dir"
  chmod 644 "$policy_file"
  echo "Chrome mandatory policies written to JSON policy file:"
  echo "  ${policy_file}"
  echo "  DnsOverHttpsMode=off"
  echo "  BuiltInDnsClientEnabled=false"
  echo "  QuicAllowed=false"

  local LOGGED_USER
  LOGGED_USER=$(stat -f "%Su" /dev/console)
  if pgrep -x "Google Chrome" > /dev/null 2>&1; then
    sudo -u "$LOGGED_USER" osascript -e 'tell application "Google Chrome" to quit' 2>/dev/null
    echo "Chrome restarted to apply policies."
    echo "Reopen Chrome — policies now active. Verify at: chrome://policy"
  else
    echo "Open Chrome — policies will apply on launch. Verify at: chrome://policy"
  fi
}

cmd_uninstall_daemon() {
  if [ -f "$DAEMON_PLIST" ]; then
    launchctl unload "$DAEMON_PLIST" 2>/dev/null
    rm -f "$DAEMON_PLIST"
    echo "Daemon removed."
  else
    echo "Daemon not installed."
  fi
}

REPO="Navibyte-Innovations-Pvt-Ltd/focuslock"

detect_brew_prefix() {
  if [ -d "/opt/homebrew/bin" ]; then
    echo "/opt/homebrew"
  elif [ -f "/usr/local/bin/brew" ]; then
    echo "/usr/local"
  else
    echo ""
  fi
}

cmd_install_tracker() {
  local brew_prefix
  brew_prefix=$(detect_brew_prefix)
  if [ -z "$brew_prefix" ]; then
    echo "Homebrew not found. Install from: https://brew.sh"
    exit 1
  fi

  local LOGGED_USER
  LOGGED_USER=$(stat -f "%Su" /dev/console)

  if [ ! -f "${brew_prefix}/bin/dnsmasq" ]; then
    echo "Installing dnsmasq via brew..."
    sudo -u "$LOGGED_USER" "${brew_prefix}/bin/brew" install dnsmasq
  fi

  ensure_state_dir

  local conf="${brew_prefix}/etc/dnsmasq.conf"
  cat > "$conf" << DNSCONF
log-queries
log-facility=${DNS_LOG}
no-resolv
server=8.8.8.8
server=1.1.1.1
listen-address=127.0.0.1
bind-interfaces
DNSCONF

  local plist_src="${brew_prefix}/opt/dnsmasq/homebrew.mxcl.dnsmasq.plist"
  if [ ! -f "$plist_src" ]; then
    echo "Error: dnsmasq plist not found at $plist_src"
    exit 1
  fi
  cp "$plist_src" "$DNSMASQ_PLIST"
  chown root:wheel "$DNSMASQ_PLIST"
  chmod 644 "$DNSMASQ_PLIST"
  launchctl unload "$DNSMASQ_PLIST" 2>/dev/null
  launchctl load -w "$DNSMASQ_PLIST"

  # Pre-create log file readable by all users — dnsmasq runs as nobody
  touch "$DNS_LOG"
  chmod 644 "$DNS_LOG"

  rm -f "$DNS_IFACE_BACKUP"
  networksetup -listallnetworkservices 2>/dev/null | tail -n +2 | while IFS= read -r svc; do
    local cur_dns
    # Avoid xargs — it chokes on "There aren't any DNS Servers set" (unmatched quote)
    cur_dns=$(networksetup -getdnsservers "$svc" 2>/dev/null | tr '\n' ' ' | sed 's/[[:space:]]*$//')
    printf '%s\t%s\n' "$svc" "$cur_dns" >> "$DNS_IFACE_BACKUP"
    networksetup -setdnsservers "$svc" 127.0.0.1 2>/dev/null || true
  done

  flush_dns
  echo "DNS tracker installed. All queries logged to: $DNS_LOG"
  echo "Run: focuslock stats  to see visited domains"
}

cmd_uninstall_tracker() {
  if [ -f "$DNS_IFACE_BACKUP" ]; then
    while IFS=$'\t' read -r svc dns; do
      if [ -z "$dns" ] || echo "$dns" | grep -qE "^There aren't|^127\.0\.0\.1$"; then
        networksetup -setdnsservers "$svc" "Empty" 2>/dev/null || true
      else
        # shellcheck disable=SC2086
        networksetup -setdnsservers "$svc" $dns 2>/dev/null || true
      fi
    done < "$DNS_IFACE_BACKUP"
    rm -f "$DNS_IFACE_BACKUP"
    echo "DNS settings restored."
  fi

  if [ -f "$DNSMASQ_PLIST" ]; then
    launchctl unload "$DNSMASQ_PLIST" 2>/dev/null
    rm -f "$DNSMASQ_PLIST"
    echo "dnsmasq daemon stopped."
  fi

  flush_dns
  echo "DNS tracker uninstalled."
}

cmd_update() {
  echo "Checking latest release..."
  local tag tmp tarball
  tag=$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" \
    | grep -m1 '"tag_name"' | cut -d'"' -f4)
  if [ -z "$tag" ]; then
    echo "Could not fetch latest tag (rate-limited or offline?)."
    exit 1
  fi
  echo "Latest: $tag"

  tmp=$(mktemp -d)
  tarball="${tmp}/focuslock.tar.gz"
  if ! curl -fsSL -o "$tarball" \
      "https://github.com/${REPO}/releases/download/${tag}/focuslock-${tag}.tar.gz"; then
    echo "Download failed."
    rm -rf "$tmp"
    exit 1
  fi

  tar -xzf "$tarball" -C "$tmp" || { echo "Extract failed."; rm -rf "$tmp"; exit 1; }

  if [ ! -f "$tmp/install.sh" ]; then
    echo "Release archive missing install.sh."
    rm -rf "$tmp"
    exit 1
  fi

  echo "Installing $tag..."
  bash "$tmp/install.sh"
  local status=$?
  rm -rf "$tmp"
  exit "$status"
}

cmd_history() {
  if [ ! -f "$HISTORY_FILE" ]; then
    echo "No history yet."
    return
  fi
  tail -n 50 "$HISTORY_FILE"
}

fmt_mins() {
  local mins=$1
  if [ "$mins" -ge 60 ]; then
    local h m
    h=$((mins / 60)); m=$((mins % 60))
    [ "$m" -gt 0 ] && echo "${h}h ${m}m" || echo "${h}h"
  else
    echo "${mins}m"
  fi
}

make_bar() {
  local val=$1 max=$2 width=${3:-20}
  local bar="" len half i=0
  [ "$max" -eq 0 ] && echo "" && return
  len=$(( val * width / max ))
  half=$(( (val * width * 2 / max) - (len * 2) ))
  while [ $i -lt $len ]; do bar="${bar}█"; i=$((i+1)); done
  [ "$half" -ge 1 ] && bar="${bar}▌"
  [ "$val" -gt 0 ] && [ -z "$bar" ] && bar="▌"
  echo "$bar"
}

cmd_stats() {
  if [ ! -f "$HISTORY_FILE" ]; then
    echo "No history yet."
    return
  fi

  # --- determine period filter ---
  local period="day" period_label date_filter
  case "${1:-}" in
    --week) period="week" ;;
    --year) period="year" ;;
    --day)  period="day"  ;;
  esac

  case "$period" in
    week)
      # Build list of dates for Mon–Sun of current week (macOS date)
      local today_dow today_epoch mon_epoch i d
      today_dow=$(date +%u)        # 1=Mon … 7=Sun
      today_epoch=$(date +%s)
      mon_epoch=$(( today_epoch - (today_dow - 1) * 86400 ))
      date_filter=""
      for i in 0 1 2 3 4 5 6; do
        d=$(date -r $(( mon_epoch + i * 86400 )) +%Y-%m-%d)
        date_filter="${date_filter}${d}|"
      done
      date_filter="${date_filter%|}"   # strip trailing |
      period_label="THIS WEEK  ($(date -r $mon_epoch +%b\ %d) – $(date -r $(( mon_epoch + 6*86400 )) +%b\ %d))"
      ;;
    year)
      date_filter=$(date +%Y)
      period_label="THIS YEAR  ($(date +%Y))"
      ;;
    *)
      date_filter=$(date +%Y-%m-%d)
      period_label="TODAY  ($(date +%b\ %d))"
      ;;
  esac

  local tmpfile hourtmp
  tmpfile=$(mktemp)
  hourtmp=$(mktemp)

  # --- aggregate per-site ---
  local max_mins=0
  while IFS= read -r site; do
    local result total_mins count
    result=$(awk -F' \\| ' -v site="$site" -v filter="$date_filter" '
      $2 ~ /^ALLOW / {
        if (filter != "" && $1 !~ filter) next
        split($2, parts, " ")
        mins = parts[2]; sub(/m$/, "", mins)
        idx = index($2, ": ")
        if (idx == 0) next
        list = substr($2, idx+2)
        n = split(list, sites, " ")
        for (i=1; i<=n; i++) {
          if (sites[i] == site) { total += mins+0; count++; break }
        }
      }
      END { print total+0, count+0 }
    ' "$HISTORY_FILE")
    total_mins=$(echo "$result" | awk '{print $1}')
    count=$(echo "$result" | awk '{print $2}')
    printf '%s %s %s\n' "$total_mins" "$count" "$site" >> "$tmpfile"
    [ "$total_mins" -gt "$max_mins" ] && max_mins="$total_mins"
  done < <(read_sites)

  # --- aggregate per-hour ---
  awk -F' \\| ' -v filter="$date_filter" '
    $2 ~ /^ALLOW / {
      if (filter != "" && $1 !~ filter) next
      split($1, dt, " ")
      split(dt[2], hms, ":")
      counts[hms[1]+0]++
    }
    END { for (h in counts) printf "%s %s\n", counts[h], h }
  ' "$HISTORY_FILE" | sort -rn > "$hourtmp"
  local peak_max=0
  [ -s "$hourtmp" ] && peak_max=$(head -1 "$hourtmp" | awk '{print $1}')

  # --- print report ---
  echo ""
  echo "  DISTRACTION REPORT — ${period_label}"
  echo "  =============================="
  echo ""
  printf "  %-22s %-9s %-7s %s\n" "SITE" "TOTAL" "ALLOWS" "USAGE"
  printf "  %s\n" "──────────────────────────────────────────────────────────"

  sort -rn "$tmpfile" | while IFS=' ' read -r mins cnt site; do
    local pretty bar
    pretty=$(fmt_mins "$mins")
    bar=$(make_bar "$mins" "$max_mins" 24)
    printf "  %-22s %-9s %-7s %s\n" "$site" "$pretty" "$cnt" "$bar"
  done

  echo ""
  echo ""
  printf "  %s\n" "PEAK ALLOW HOURS"
  printf "  %s\n" "──────────────────────────────────────────────────────────"

  while IFS=' ' read -r cnt hour; do
    local label bar
    if [ "$hour" -ge 12 ]; then
      [ "$hour" -eq 12 ] && label="12 PM" || label="$(( hour - 12 )) PM"
    else
      [ "$hour" -eq 0 ] && label="12 AM" || label="${hour} AM"
    fi
    bar=$(make_bar "$cnt" "$peak_max" 24)
    printf "  %6s  %-26s (%s allows)\n" "$label" "$bar" "$cnt"
  done < "$hourtmp"

  echo ""
  rm -f "$tmpfile" "$hourtmp"

  # --- DNS visit stats (only if dnsmasq tracker is installed) ---
  if [ ! -s "$DNS_LOG" ]; then
    return
  fi

  # Build date filter in syslog "MMM D" format (awk collapses spaces so $2+0 = day number)
  local dns_filter dm dd
  case "$period" in
    week)
      dns_filter=""
      for i in 0 1 2 3 4 5 6; do
        dm=$(date -r $(( mon_epoch + i * 86400 )) '+%b')
        dd=$(date -r $(( mon_epoch + i * 86400 )) '+%e' | tr -d ' ')
        dns_filter="${dns_filter}${dm} ${dd}|"
      done
      dns_filter="${dns_filter%|}"
      ;;
    year)
      dns_filter=""
      ;;
    *)
      dm=$(date '+%b')
      dd=$(date '+%e' | tr -d ' ')
      dns_filter="${dm} ${dd}"
      ;;
  esac

  local dns_tmp
  dns_tmp=$(mktemp)

  awk -v filter="$dns_filter" '
    /query\[A/ {
      date_str = $1 " " ($2+0)
      if (filter != "" && date_str !~ filter) next

      domain = ""
      for (i = 1; i <= NF; i++) {
        if ($i ~ /query\[/) { domain = $(i+1); break }
      }
      if (domain == "") next
      if (domain ~ /^[0-9]/ || domain == "localhost" || domain ~ /\.arpa\.?$/) next

      sub(/\.$/, "", domain)

      n = split(domain, parts, ".")
      sld = (n >= 2) ? parts[n-1] "." parts[n] : domain
      counts[sld]++
    }
    END { for (d in counts) printf "%s %s\n", counts[d], d }
  ' "$DNS_LOG" | sort -rn | head -15 > "$dns_tmp"

  if [ -s "$dns_tmp" ]; then
    local dns_max
    dns_max=$(head -1 "$dns_tmp" | awk '{print $1}')

    echo ""
    echo "  TOP VISITED DOMAINS"
    printf "  %s\n" "──────────────────────────────────────────────────────────"
    printf "  %-30s %-8s %s\n" "DOMAIN" "QUERIES" "FREQUENCY"
    printf "  %s\n" "──────────────────────────────────────────────────────────"

    while IFS=' ' read -r cnt domain; do
      local bar
      bar=$(make_bar "$cnt" "$dns_max" 24)
      printf "  %-30s %-8s %s\n" "$domain" "$cnt" "$bar"
    done < "$dns_tmp"

    echo ""
  fi

  rm -f "$dns_tmp"
}

# Normalize user-supplied domain: strip protocol, www., path, port, trailing slash.
# Without this, `focuslock add https://www.reddit.com` wrote a junk hosts line
# (`127.0.0.1 https://www.reddit.com`) that never matched any DNS lookup.
sanitize_domain() {
  local raw="$1"
  raw="${raw#http://}"
  raw="${raw#https://}"
  raw="${raw#www.}"
  raw="${raw%%/*}"   # strip any path
  raw="${raw%%:*}"   # strip any port
  raw="${raw%%\?*}"  # strip any query
  echo "$raw"
}

cmd_add() {
  ensure_config
  repair_bad_entries
  local site
  site=$(sanitize_domain "$1")
  [ -z "$site" ] && echo "Usage: focuslock add <domain>" && exit 1

  if grep -qxF "$site" "$SITES_FILE" 2>/dev/null; then
    echo "$site already in list"
    exit 0
  fi

  echo "$site" >> "$SITES_FILE"

  if ! grep -qE "127\.0\.0\.1[[:space:]]+${site//./\\.}" "$HOSTS"; then
    printf "127.0.0.1\t%s\n127.0.0.1\twww.%s\n" "$site" "$site" >> "$HOSTS"
  fi
  if ! grep -qE "^::1[[:space:]]+${site//./\\.}" "$HOSTS"; then
    printf "::1\t%s\n::1\twww.%s\n" "$site" "$site" >> "$HOSTS"
  fi

  flush_dns
  echo "Added and blocked: $site"
}

cmd_remove() {
  ensure_config
  local site
  site=$(sanitize_domain "$1")
  [ -z "$site" ] && echo "Usage: focuslock remove <domain>" && exit 1

  # Match either the sanitized form, or any raw form left from buggy older adds
  local raw_pattern
  raw_pattern=$(printf '%s\n' "$1" | sed 's/[][\\.*^$/]/\\&/g')
  sed -i '' "/^${site}$/d" "$SITES_FILE"
  [ "$raw_pattern" != "$site" ] && sed -i '' "/^${raw_pattern}$/d" "$SITES_FILE"
  sed -i '' -E "/(127\.0\.0\.1|::1)[[:space:]]+(www\.)?${site//./\\.}/d" "$HOSTS"
  [ "$raw_pattern" != "$site" ] && sed -i '' -E "/(127\.0\.0\.1|::1)[[:space:]]+${raw_pattern//./\\.}/d" "$HOSTS"

  flush_dns
  echo "Removed: $site"
}

cmd_list() {
  ensure_config
  echo "Blocked sites:"
  while IFS= read -r site; do
    escaped="${site//./\\.}"
    if grep -qE "^#[[:space:]]*127\.0\.0\.1[[:space:]]+(www\.)?${escaped}" "$HOSTS" 2>/dev/null; then
      echo "  $site  [ALLOWED now]"
    else
      echo "  $site  [blocked]"
    fi
  done < <(read_sites)
}

cmd_status() {
  if [ -f "$EXPIRES_FILE" ]; then
    EXP=$(cat "$EXPIRES_FILE" 2>/dev/null)
    NOW=$(date +%s)
    if [ -n "$EXP" ] && [ "$NOW" -lt "$EXP" ]; then
      REMAIN=$(( (EXP - NOW + 59) / 60 ))
      echo "Status: ALLOWING (${REMAIN} min left, reblocks at $(date -r "$EXP" '+%I:%M %p'))"
      [ -f "$ALLOWED_FILE" ] && echo "Sites:" && sed 's/^/  /' "$ALLOWED_FILE"
    else
      echo "Status: BLOCKED (expiry passed — daemon will reblock within 60s, or run: sudo focuslock block)"
    fi
  else
    echo "Status: BLOCKED"
  fi
  if [ -f "$DAEMON_PLIST" ]; then
    echo "Daemon : installed"
  else
    echo "Daemon : NOT installed — run: sudo focuslock install-daemon"
  fi
}

cmd_help() {
  cat << 'HELP'
focuslock — temporary site blocker for macOS

Usage:
  sudo focuslock allow             pick sites + duration, auto-reblocks
  sudo focuslock block             reblock immediately
  sudo focuslock add <domain>      add site to block list
  sudo focuslock remove <domain>   remove site from block list
  focuslock list                   show all sites + current state
  focuslock status                 show timer + daemon status
  focuslock history                show allow/block history
  focuslock stats                  show per-site total allowed time (ranked)
  sudo focuslock check             reblock if expiry passed (daemon uses this)
  sudo focuslock install-daemon       install LaunchDaemon (runs at boot, every 60s)
  sudo focuslock uninstall-daemon     remove LaunchDaemon
  sudo focuslock disable-chrome-doh   stop Chrome bypassing /etc/hosts via DoH
  sudo focuslock install-tracker      install dnsmasq to log all DNS queries
  sudo focuslock uninstall-tracker    remove dnsmasq DNS tracker
  sudo focuslock update               download + install latest release from GitHub

Config: ~/.focuslock/sites (one domain per line)
HELP
}

case "$COMMAND" in
  allow)              shift; cmd_allow "$@" ;;
  block)              shift; cmd_block "$@" ;;
  add)                shift; cmd_add "$@" ;;
  remove)             shift; cmd_remove "$@" ;;
  list)               cmd_list ;;
  status)             cmd_status ;;
  history)            cmd_history ;;
  stats)              shift; cmd_stats "$@" ;;
  check)              cmd_check ;;
  install-daemon)     cmd_install_daemon ;;
  uninstall-daemon)   cmd_uninstall_daemon ;;
  disable-chrome-doh) cmd_disable_chrome_doh ;;
  install-tracker)    cmd_install_tracker ;;
  uninstall-tracker)  cmd_uninstall_tracker ;;
  update)             cmd_update ;;
  *)                  cmd_help ;;
esac
